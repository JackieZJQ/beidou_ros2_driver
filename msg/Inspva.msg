std_msgs/Header header   # Ros 时间戳

float64 latitude         # WGS84 纬度
float64 longitude        # WGS84 经度
float64 height           # WGS84 海拔高度
float64 north_velocity   # 北向速度
float64 east_velocity    # 东向速度
float64 up_velocity      # 天向速度
float64 roll             # 车辆滚转角，指向车辆前方
float64 pitch            # 车辆俯仰角，指向车辆右侧
float64 azimuth          # 车辆航向角